{
  "nodes": [
    {
      "id": "0",
      "type": "text",
      "text": "Sam Altman 访谈：OpenAI 与 AI 的未来",
      "x": 0,
      "y": 828,
      "width": 280,
      "height": 52,
      "color": "6"
    },
    {
      "id": "1",
      "type": "text",
      "text": "OpenAI 组织演变",
      "x": 360,
      "y": 108,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "2",
      "type": "text",
      "text": "早期被嘲讽：2015年宣布致力于 AGI",
      "x": 680,
      "y": 0,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "3",
      "type": "text",
      "text": "非营利转向上限盈利：获取资本与算力需求",
      "x": 680,
      "y": 72,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "4",
      "type": "text",
      "text": "核心团队：Sam Altman, Ilya Sutskever, Greg Brockman",
      "x": 680,
      "y": 144,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "5",
      "type": "text",
      "text": "治理结构：非营利董事会保留最终控制权",
      "x": 680,
      "y": 216,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "6",
      "type": "text",
      "text": "GPT-4 技术核心",
      "x": 360,
      "y": 432,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "7",
      "type": "text",
      "text": "预训练：海量文本数据，构建底层表征",
      "x": 680,
      "y": 288,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "8",
      "type": "text",
      "text": "RLHF：人类反馈强化学习，提升可用性与对齐",
      "x": 680,
      "y": 360,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "9",
      "type": "text",
      "text": "科学预测：能准确预测模型在训练后的表现",
      "x": 680,
      "y": 432,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "10",
      "type": "text",
      "text": "推理引擎：超越数据库，具备初步推理能力",
      "x": 680,
      "y": 504,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "11",
      "type": "text",
      "text": "System Message：增强用户对模型的引导与控制",
      "x": 680,
      "y": 576,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "12",
      "type": "text",
      "text": "AI 安全与对齐",
      "x": 360,
      "y": 756,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "13",
      "type": "text",
      "text": "红队测试：发布前长达数月的内部与外部审计",
      "x": 680,
      "y": 648,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "14",
      "type": "text",
      "text": "对齐挑战：目前尚无对齐超强智能的定论",
      "x": 680,
      "y": 720,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "15",
      "type": "text",
      "text": "偏差与偏见：力求中立，通过用户控制解决细分偏见",
      "x": 680,
      "y": 792,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "16",
      "type": "text",
      "text": "迭代部署：在低风险阶段发现并修正错误",
      "x": 680,
      "y": 864,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "17",
      "type": "text",
      "text": "社会影响与转型",
      "x": 360,
      "y": 1044,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "18",
      "type": "text",
      "text": "经济冲击：智能与能源成本大幅下降",
      "x": 680,
      "y": 936,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "19",
      "type": "text",
      "text": "就业变革：自动化低端工作，增强创造性岗位",
      "x": 680,
      "y": 1008,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "20",
      "type": "text",
      "text": "UBI（全民基本收入）：作为社会转型期的缓冲",
      "x": 680,
      "y": 1080,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "21",
      "type": "text",
      "text": "信息风险：担忧大规模虚假信息与地缘政治操纵",
      "x": 680,
      "y": 1152,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "22",
      "type": "text",
      "text": "AGI 的未来探讨",
      "x": 360,
      "y": 1332,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "23",
      "type": "text",
      "text": "起飞速度：倾向于“短时间、慢起飞”的轨迹",
      "x": 680,
      "y": 1224,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "24",
      "type": "text",
      "text": "超智能定义：必须能对科学知识总量做出实质贡献",
      "x": 680,
      "y": 1296,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "25",
      "type": "text",
      "text": "意识与生物性：倾向于认为 AI 是工具而非生物",
      "x": 680,
      "y": 1368,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "26",
      "type": "text",
      "text": "权力分配：决策应随时间推移更加民主化",
      "x": 680,
      "y": 1440,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "27",
      "type": "text",
      "text": "人物观点与外部关系",
      "x": 360,
      "y": 1584,
      "width": 240,
      "height": 52,
      "color": "5"
    },
    {
      "id": "28",
      "type": "text",
      "text": "与 Elon Musk 的分歧：认同 AGI 风险但路径不同",
      "x": 680,
      "y": 1512,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "29",
      "type": "text",
      "text": "与 Microsoft 的合作：Satya Nadella 的领导力与算力支持",
      "x": 680,
      "y": 1584,
      "width": 200,
      "height": 52,
      "color": "4"
    },
    {
      "id": "30",
      "type": "text",
      "text": "面对批评：保持透明度，在公众质疑中持续进步",
      "x": 680,
      "y": 1656,
      "width": 200,
      "height": 52,
      "color": "4"
    }
  ],
